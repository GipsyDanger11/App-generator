{
  "name": "app-generator",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "db:push": "prisma db push",
    "db:generate": "prisma generate",
    "db:studio": "prisma studio",
    "postinstall": "prisma generate",
    "ai:setup": "cd ai-service && python -m venv .venv && .venv\\Scripts\\pip install --prefer-binary -r requirements.txt",
    "ai:start": "cd ai-service && .venv\\Scripts\\uvicorn main:app --host 0.0.0.0 --port 8000 --reload",
    "ai:test": "cd ai-service && set PYTHONIOENCODING=utf-8 && .venv\\Scripts\\python test_service.py",
    "ai:health": "curl -s http://localhost:8000/health"
  },
  "dependencies": {
    "@auth/prisma-adapter": "2.7.4",
    "@octokit/rest": "^21.0.2",
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^2.4.3",
    "clsx": "^2.1.1",
    "lucide-react": "^0.468.0",
    "next": "^16.2.7",
    "next-auth": "^4.24.14",
    "papaparse": "^5.4.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwind-merge": "^2.5.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.17.10",
    "@types/papaparse": "^5.3.15",
    "@types/react": "^18.3.16",
    "@types/react-dom": "^18.3.5",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.1",
    "eslint-config-next": "^16.2.7",
    "jest": "^30.4.2",
    "postcss": "^8.4.49",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.4.16",
    "ts-jest": "^29.4.11",
    "typescript": "^5.7.2"
  }
}
